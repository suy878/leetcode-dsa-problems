class Solution {
    public char findTheDifference(String s, String t) {
        char[] ch = s.toCharArray();
        char[] cr = t.toCharArray();

        Arrays.sort(ch);
        Arrays.sort(cr);

        StringBuilder er = new StringBuilder();
        for(int i =0 ;i<ch.length;i++){
            if(ch[i]!=cr[i]){
                return cr[i];

            }
        }
       return cr[cr.length-1];
    }
}
