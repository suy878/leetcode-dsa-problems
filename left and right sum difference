class Solution {
    public int[] leftRightDifference(int[] nums) {
        int leftSum = 0;
        int rightSum = 0;
        
        // 1. Calculate the total sum of all elements (this is our starting rightSum)
        for (int num : nums) {
            rightSum += num;
        }
        
        int[] answer = new int[nums.length];
        
        // 2. Compute the absolute difference on the fly
        for (int i = 0; i < nums.length; i++) {
            // Remove current element from rightSum since it's no longer to the right
            rightSum -= nums[i]; 
            
            // Calculate absolute difference between running left and right sums
            answer[i] = Math.abs(leftSum - rightSum); 
            
            // Add current element to leftSum for the next index
            leftSum += nums[i]; 
        }
        
        return answer;
    }
}
